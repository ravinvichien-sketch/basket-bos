# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LINE Login channel (LINE Developers Console → LINE Login)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# LIFF (optional — deep links inside LINE)
NEXT_PUBLIC_LIFF_ID=

# LINE Messaging API channel (สำหรับ push แจ้งเตือน — คนละ channel กับ LINE Login)
# ไม่ใส่ก็ได้ แอปทำงานปกติแต่ไม่มี push
LINE_MESSAGING_TOKEN=
LINE_MESSAGING_CHANNEL_SECRET=

# PromptPay กลางของก๊วน (fallback) — ใช้เมื่อยังไม่ได้แต่งตั้งคนเก็บเงิน
# หรือคนเก็บเงินยังไม่ใส่ PromptPay ของตัวเอง
# ถ้าแต่ละเกมมีคนเก็บเงินใส่บัญชีตัวเองแล้ว ระบบจะใช้บัญชีคนนั้นก่อนเสมอ
# เบอร์มือถือ (0812345678) หรือเลขบัตรประชาชน 13 หลัก
PROMPTPAY_ID=

# Long random string — used to derive per-user auth secrets. NEVER change after launch.
AUTH_PASSWORD_SECRET=generate-a-long-random-string-at-least-32-chars

# (ไม่บังคับ) สำหรับฟีเจอร์ "ให้ AI แต่งรูปการ์ด" — platform.openai.com
OPENAI_API_KEY=
